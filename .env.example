# Copy this file to .env and fill in real values.
OPENROUTER_API_KEY=
DISCORD_VISION_FORGE_WEBHOOK_URL=

# Required server-only secret used to sign/verify Discord preview tokens.
# Use any long random string (e.g. `openssl rand -hex 32`). Never expose to the client.
VISION_FORGE_SIGNING_SECRET=

# Optional overrides.
OPENROUTER_MODEL=openai/gpt-5.2
SITE_URL=http://localhost:3000

# Alchemist Streamers Hub (server-only Twitch credentials).
# Create an application at https://dev.twitch.tv/console to get these.
# Treat them like passwords — never expose to the client, never commit real values.
# If omitted, /streamers still renders the approved roster with everyone offline.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
