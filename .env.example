# Copy this file to .env and fill in real values.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

DISCORD_VISION_FORGE_WEBHOOK_URL=
GAME_SIGNAL_DISCORD_WEBHOOK_URL=
GAME_SIGNAL_REACTION_THRESHOLD=2
GAME_SIGNAL_AUTO_PUBLISH=true
GAME_SIGNAL_PUBLISH_SECRET=

# Required server-only secret used to sign/verify Discord preview tokens.
# Use any long random string (e.g. `openssl rand -hex 32`). Never expose to the client.
VISION_FORGE_SIGNING_SECRET=

# Optional overrides.
SITE_URL=http://localhost:3000
