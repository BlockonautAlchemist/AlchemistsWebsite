{
  "buildCommand": "npm run build",
  "cleanUrls": true,
  "devCommand": "vite --host 127.0.0.1 --port $PORT",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/vision-forge",
      "destination": "/vision-forge.html"
    },
    {
      "source": "/game-signal-engine",
      "destination": "/game-signal-engine.html"
    },
    {
      "source": "/games/(.*)",
      "destination": "/game.html"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ]
}
